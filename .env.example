# Almanac server configuration
#
# Copy this file to `.env` for local development:
#   cp .env.example .env
#
# All values are optional. Defaults are safe for local development.

# Server
PORT=8080
DATA_DIR=.

# Catalog scope (optional; omit to include the full catalog)
# CATALOG_INCLUDE_PROVIDERS=openai,anthropic
# CATALOG_EXCLUDE_PROVIDERS=
# CATALOG_INCLUDE_MODELS=openai/gpt-4o,anthropic/claude-sonnet-4-6
# CATALOG_EXCLUDE_MODELS=
# CATALOG_SCOPE_FILE=scope.yaml

# Redis (optional; required for redis-backed rate limiting and caching)
# REDIS_URL=rediss://default:<token>@<host>.upstash.io:6379

# Rate limiting
# Omit RATE_LIMIT_RPS to disable locally. Set it for public deployments.
# RATE_LIMIT_RPS=10
# RATE_LIMIT_BACKEND=memory   # memory (default) or redis

# Proxy headers
# Keep false/omitted when running directly on the internet. Set true only when
# the app is behind a trusted proxy such as Render, Cloudflare, Fly, or Railway.
# TRUST_PROXY_HEADERS=true

# Response caching
# CACHE_BACKEND=none          # none (default), memory, or redis
# CACHE_TTL_SECS=300

# Logging
# RUST_LOG=almanac_server=info,tower_http=warn
# LOG_FORMAT=json             # omit for human-readable, set to "json" for structured logs
