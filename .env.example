# Server
PORT=8080
DATA_DIR=.

# Catalog scope (optional — omit to include everything)
# CATALOG_INCLUDE_PROVIDERS=openai,anthropic
# CATALOG_EXCLUDE_PROVIDERS=
# CATALOG_INCLUDE_MODELS=
# CATALOG_EXCLUDE_MODELS=
# CATALOG_SCOPE_FILE=scope.json

# Redis (optional — required for redis-backed rate limiting and caching)
# REDIS_URL=rediss://default:<token>@<host>.upstash.io:6379

# Rate limiting (optional — omit RATE_LIMIT_RPS to disable)
# RATE_LIMIT_RPS=10
# RATE_LIMIT_BACKEND=memory   # memory (default) | redis

# Response caching
# CACHE_BACKEND=none          # none (default) | memory | redis
# CACHE_TTL_SECS=300

# Logging
# RUST_LOG=almanac_server=info,tower_http=warn
# LOG_FORMAT=json             # omit for human-readable, set to "json" for structured logs
