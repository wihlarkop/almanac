{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "required": [
    "id",
    "provider",
    "display_name",
    "status",
    "context_window",
    "max_output_tokens",
    "modalities",
    "capabilities",
    "parameters",
    "last_verified",
    "confidence",
    "endpoint_family",
    "sources"
  ],
  "additionalProperties": false,
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9._-]*$",
      "description": "Canonical model identifier. Must match the filename (without .yaml)."
    },
    "provider": {
      "type": "string",
      "description": "Must match a provider id in providers/"
    },
    "display_name": {
      "type": "string"
    },
    "status": {
      "type": "string",
      "enum": ["active", "deprecating", "deprecated", "retired"]
    },
    "release_date": {
      "type": ["string", "null"],
      "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
    },
    "deprecation_date": {
      "type": ["string", "null"],
      "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
    },
    "sunset_date": {
      "type": ["string", "null"],
      "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
    },
    "replacement": {
      "type": ["string", "null"],
      "description": "Canonical id of the successor model"
    },
    "context_window": {
      "type": "integer",
      "minimum": 1
    },
    "max_output_tokens": {
      "type": "integer",
      "minimum": 1
    },
    "modalities": {
      "type": "object",
      "required": ["input", "output"],
      "additionalProperties": false,
      "properties": {
        "input": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": ["text", "image", "audio", "video", "file"]
          },
          "minItems": 1,
          "uniqueItems": true
        },
        "output": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": ["text", "image", "audio", "video", "embedding", "music", "3d"]
          },
          "minItems": 1,
          "uniqueItems": true
        }
      }
    },
    "capabilities": {
      "type": "object",
      "additionalProperties": {
        "type": "boolean"
      },
      "description": "Open-ended boolean flags. Any capability key is allowed."
    },
    "parameters": {
      "type": "object",
      "required": ["supported", "rejected", "deprecated_for_this_model"],
      "additionalProperties": false,
      "properties": {
        "supported": {
          "type": "array",
          "items": { "type": "string" },
          "uniqueItems": true
        },
        "rejected": {
          "type": "array",
          "items": { "type": "string" },
          "uniqueItems": true,
          "description": "Params the model actively rejects (throws an error if passed)"
        },
        "deprecated_for_this_model": {
          "type": "array",
          "items": { "type": "string" },
          "uniqueItems": true,
          "description": "Params still accepted but should not be used with this model"
        }
      }
    },
    "last_verified": {
      "type": "string",
      "pattern": "^\\d{4}-\\d{2}-\\d{2}$",
      "description": "Date this model entry was last reviewed against its sources."
    },
    "confidence": {
      "type": "string",
      "enum": ["official", "inferred", "community", "unknown"],
      "description": "Confidence level for the model metadata."
    },
    "endpoint_family": {
      "type": "string",
      "enum": ["chat_completions", "responses", "custom", "agent", "search", "embeddings", "reranking", "image_generation", "speech", "transcription", "video_generation", "realtime", "ocr", "music_generation", "mesh_generation"],
      "description": "Primary API shape used by this provider/model."
    },
    "pricing": {
      "type": "object",
      "required": ["currency", "input", "output"],
      "additionalProperties": false,
      "properties": {
        "currency": {
          "type": "string",
          "pattern": "^[A-Z]{3}$"
        },
        "input": {
          "type": "number",
          "minimum": 0,
          "description": "Price per 1M input tokens"
        },
        "output": {
          "type": "number",
          "minimum": 0,
          "description": "Price per 1M output tokens"
        },
        "cached_input": {
          "type": "number",
          "minimum": 0,
          "description": "Cached input price per 1M tokens, when published."
        },
        "batch_input": {
          "type": "number",
          "minimum": 0,
          "description": "Batch input price per 1M tokens, when published."
        },
        "batch_output": {
          "type": "number",
          "minimum": 0,
          "description": "Batch output price per 1M tokens, when published."
        },
        "request_fee": {
          "type": "number",
          "minimum": 0,
          "description": "Flat request fee, when applicable."
        },
        "search_fee": {
          "type": "number",
          "minimum": 0,
          "description": "Search fee, when applicable."
        },
        "reasoning": {
          "type": "number",
          "minimum": 0,
          "description": "Reasoning-token price per 1M tokens, when separate."
        },
        "per_image": {
          "type": "number",
          "minimum": 0,
          "description": "Price per image generated (image generation models)."
        },
        "per_second": {
          "type": "number",
          "minimum": 0,
          "description": "Price per second of audio output (TTS models)."
        },
        "per_minute": {
          "type": "number",
          "minimum": 0,
          "description": "Price per minute of audio input (transcription models)."
        },
        "per_million_chars": {
          "type": "number",
          "minimum": 0,
          "description": "Price per 1M characters (TTS models priced by character)."
        },
        "per_page": {
          "type": "number",
          "minimum": 0,
          "description": "Price per page processed (OCR/document models)."
        },
        "pricing_notes": {
          "type": "string"
        }
      }
    },
    "sources": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["url", "last_verified"],
        "additionalProperties": false,
        "properties": {
          "url": { "type": "string" },
          "last_verified": {
            "type": "string",
            "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
          }
        }
      }
    }
  }
}
