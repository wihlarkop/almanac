{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "required": [
    "id",
    "provider",
    "display_name",
    "status",
    "context_window",
    "max_output_tokens",
    "modalities",
    "capabilities",
    "parameters",
    "sources"
  ],
  "additionalProperties": false,
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9._-]*$",
      "description": "Canonical model identifier. Must match the filename (without .yaml)."
    },
    "provider": {
      "type": "string",
      "description": "Must match a provider id in providers/"
    },
    "display_name": {
      "type": "string"
    },
    "status": {
      "type": "string",
      "enum": ["active", "deprecating", "deprecated", "retired"]
    },
    "release_date": {
      "type": ["string", "null"],
      "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
    },
    "deprecation_date": {
      "type": ["string", "null"],
      "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
    },
    "sunset_date": {
      "type": ["string", "null"],
      "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
    },
    "replacement": {
      "type": ["string", "null"],
      "description": "Canonical id of the successor model"
    },
    "context_window": {
      "type": "integer",
      "minimum": 1
    },
    "max_output_tokens": {
      "type": "integer",
      "minimum": 1
    },
    "modalities": {
      "type": "object",
      "required": ["input", "output"],
      "additionalProperties": false,
      "properties": {
        "input": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": ["text", "image", "audio", "video", "file"]
          },
          "minItems": 1,
          "uniqueItems": true
        },
        "output": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": ["text", "image", "audio"]
          },
          "minItems": 1,
          "uniqueItems": true
        }
      }
    },
    "capabilities": {
      "type": "object",
      "additionalProperties": {
        "type": "boolean"
      },
      "description": "Open-ended boolean flags. Any capability key is allowed."
    },
    "parameters": {
      "type": "object",
      "required": ["supported", "rejected", "deprecated_for_this_model"],
      "additionalProperties": false,
      "properties": {
        "supported": {
          "type": "array",
          "items": { "type": "string" },
          "uniqueItems": true
        },
        "rejected": {
          "type": "array",
          "items": { "type": "string" },
          "uniqueItems": true,
          "description": "Params the model actively rejects (throws an error if passed)"
        },
        "deprecated_for_this_model": {
          "type": "array",
          "items": { "type": "string" },
          "uniqueItems": true,
          "description": "Params still accepted but should not be used with this model"
        }
      }
    },
    "pricing": {
      "type": "object",
      "required": ["currency", "input", "output"],
      "additionalProperties": false,
      "properties": {
        "currency": {
          "type": "string",
          "pattern": "^[A-Z]{3}$"
        },
        "input": {
          "type": "number",
          "minimum": 0,
          "description": "Price per 1M input tokens"
        },
        "output": {
          "type": "number",
          "minimum": 0,
          "description": "Price per 1M output tokens"
        }
      }
    },
    "sources": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["url", "last_verified"],
        "additionalProperties": false,
        "properties": {
          "url": { "type": "string" },
          "last_verified": {
            "type": "string",
            "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
          }
        }
      }
    }
  }
}
